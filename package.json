{
  "name": "entry-apk",
  "version": "1.0.0",
  "private": true,
  "description": "Entry Offline Workspace packaged as Android APK (Capacitor)",
  "scripts": {
    "fetch": "bash scripts/fetch_entry_assets.sh",
    "bundle": "node scripts/make_bundle.js",
    "cap:sync": "npx cap sync android",
    "apk:debug": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2"
  },
  "devDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
