{
  "name": "entry-apk",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Entry Offline Editor APK (Capacitor + bundled EntryJS)",
  "scripts": {
    "fetch": "bash scripts/fetch_entry_assets.sh",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "build:android": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/assets": "^1.0.0"
  }
}
